# OmniAgent Remote Server 环境变量示例（L2 §11.3 — M2 iter 4）
#
# 用法：
#   1. cp .env.example .env
#   2. 编辑 .env 填入实际值
#   3. docker compose up -d

# ============================================================
# LLM Provider 配置（必填）
# ============================================================

# Provider ID（openai / anthropic / bedrock / ollama）
OMNIAGENT_LLM_PROVIDER=openai

# Provider API Key（必填，除非用 ollama 本地）
OMNIAGENT_LLM_API_KEY=sk-...

# 模型 ID（可选，默认按 provider 选）
OMNIAGENT_LLM_MODEL=

# Fallback 模型（可选，主模型失败时切换）
OMNIAGENT_LLM_FALLBACK=

# 自定义 endpoint（可选，用于代理或私有部署）
OMNIAGENT_LLM_BASE_URL=

# ============================================================
# Bedrock 专用（可选）
# ============================================================
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_SESSION_TOKEN=...

# ============================================================
# OmniAgent 运行时配置（可选）
# ============================================================

# 最大并发 agent（默认 16）
OMNIAGENT_MAX_CONCURRENT_AGENTS=16

# Workflow Orchestrator 开关（决策 A3 默认 off，设 1 启用）
OMNIAGENT_WORKFLOW_ORCHESTRATOR=0

# ============================================================
# SSH Server 配置（Remote Server 模式专用）
# ============================================================

# SSH 端口（容器内 sshd 监听，默认 2222）
# OMNIAGENT_SSH_PORT=2222

# SSH 公钥（用于客户端认证，多行用引号）
# OMNIAGENT_SSH_AUTHORIZED_KEYS="ssh-ed25519 AAAA... user@host"

# ============================================================
# 资源限制（可选）
# ============================================================

# 容器内存上限
# MEMORY_LIMIT=2g

# 容器 CPU 上限
# CPU_LIMIT=2.0
