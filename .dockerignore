# OmniAgent CLI .dockerignore（L2 §11.3 — M2 iter 4）
#
# 排除不必要文件，减小 build context 大小，加速 docker build。
# 与 .gitignore 部分重合，但 Docker 单独维护以便精确控制。

# ============================================================
# 版本控制
# ============================================================
.git
.gitignore
.github
.gitlab

# ============================================================
# Node.js 依赖与构建产物（在 image 内重新生成）
# ============================================================
node_modules
dist
**/node_modules
**/dist

# ============================================================
# 测试与文档（运行时不需要）
# ============================================================
tests
**/*.test.ts
**/*.spec.ts
**/*.test.js
**/*.spec.js

doc
docs
*.md
!README.md

eval
examples
scripts

# ============================================================
# 打包与分发
# ============================================================
packaging
*.tar.gz
*.tgz
*.zip
*.deb
*.rpm
*.dmg

# ============================================================
# IDE / 编辑器
# ============================================================
.vscode
.idea
*.swp
*.swo
*~

# ============================================================
# 环境与密钥（不进镜像）
# ============================================================
.env
.env.local
.env.production
.env.development
*.pem
*.key
secrets/

# ============================================================
# 运行时数据（运行时挂载，不入镜像）
# ============================================================
.omniagent
**/.omniagent

# ============================================================
# 临时与缓存
# ============================================================
.cache
*.log
*.pid
*.seed
.DS_Store
Thumbs.db

# ============================================================
# CI / CD
# ============================================================
.gitlab-ci.yml
.travis.yml
.circleci
